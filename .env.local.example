# Next.js — copy this file to `.env.local` (gitignored). Do not commit real secrets.
#
# NEXT_PUBLIC_* vars are embedded in the browser bundle.
# All other keys here are server-only (e.g. `src/app/api/chat/route.ts`).

# Chat: "bedrock" (POST /api/chat) or "fastapi" (POST {NEXT_PUBLIC_API_URL}/query)
NEXT_PUBLIC_CHAT_BACKEND=bedrock
# Used for FastAPI URL and for Bedrock→FastAPI fallback; not used by Python as a required key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Bedrock + AWS (server-side only; never prefix these with NEXT_PUBLIC_)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional, temporary credentials

BEDROCK_KB_ID=your_knowledge_base_id
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-west-2:ACCOUNT:...your-model-arn...
